{
  "name": "packlift",
  "version": "1.0.1",
  "description": "A CLI for inspecting and updating outdated Composer dependencies",
  "author": "Poshtive",
  "license": "MIT",
  "keywords": [
    "composer",
    "php",
    "dependencies",
    "update",
    "cli",
    "packagist",
    "outdated"
  ],
  "type": "module",
  "main": "./dist/cli.mjs",
  "module": "./dist/cli.mjs",
  "bin": {
    "packlift": "bin/packlift.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --outfile dist/cli.mjs --target node",
    "prepublishOnly": "bun run build",
    "test": "bun test"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/poshtive/packlift.git"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/prompts": "^2.4.9",
    "@types/semver": "^7.7.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "cac": "^7.0.0",
    "detect-indent": "^7.0.2",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "semver": "^7.7.4"
  }
}
